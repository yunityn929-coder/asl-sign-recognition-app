rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isValidUserCreate() {
      let data = request.resource.data;
      return data.uid is string
        && data.email is string
        && data.createdAt is timestamp
        && data.totalXp is number && data.totalXp >= 0
        && data.currentStreak is number && data.currentStreak >= 0
        && data.isAnonymous is bool;
    }

    function isValidUserUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidLesson() {
      let data = request.resource.data;
      return data.lessonId is string
        && data.status in ['locked', 'available', 'completed']
        && data.totalXpEarned is number && data.totalXpEarned >= 0;
    }

    function isValidPracticeResult() {
      let data = request.resource.data;
      return data.lessonId is string
        && data.correctCount is number && data.correctCount >= 0
        && data.totalItems is number && data.totalItems >= 0
        && data.accuracyPercent is number
        && data.completedAt is timestamp
        && data.sessionType is string
        && data.xpEarned is number && data.xpEarned >= 0;
    }

    function isValidDailyQuest(dateStr) {
      return dateStr.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidCalibrationSample() {
      return request.resource.data.samples is list;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUserCreate();
      allow update: if isOwner(uid) && isValidUserUpdate();
      allow delete: if isOwner(uid);

      match /lessons/{lessonId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isValidLesson();
        allow delete: if isOwner(uid);
      }

      match /practiceResults/{resultId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidPracticeResult();
        allow update: if false;
        allow delete: if isOwner(uid);
      }

      match /dailyQuests/{dateStr} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isValidDailyQuest(dateStr);
        allow delete: if isOwner(uid);
      }

      match /calibration/{signLabel} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isValidCalibrationSample();
        allow delete: if isOwner(uid);
      }
    }

    match /deletedGoogleAccounts/{googleUid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.firebaseUid;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == resource.data.firebaseUid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
